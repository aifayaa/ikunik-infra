{
  "extends": "airbnb-base",
  "rules": {
    "import/prefer-default-export": "allow",
    "no-bitwise": [
      "error",
      {
        "int32Hint": true
      }
    ],
    "no-underscore-dangle": [
      "error",
      {
        "allow": ["_id"]
      }
    ],
    "object-curly-newline": [
      "error",
      {
        "minProperties": 10,
        "consistent": true
      }
    ]
  }
}
