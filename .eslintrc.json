{
  "extends": "airbnb-base",
  "rules": {
    "operator-linebreak": ["error", "after", { "overrides": { "?": "off", ":": "before" } }],
    "import/prefer-default-export": "off",
    "no-param-reassign": "off",
    "require-await": "error",
    "no-bitwise": [
      "error",
      {
        "int32Hint": true
      }
    ],
    "no-underscore-dangle": [
      "error",
      {
        "allow": ["_id", "__"]
      }
    ],
    "object-curly-newline": [
      "error",
      {
        "minProperties": 10,
        "consistent": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["*.test.js"],
      "rules": {
        "no-unused-expressions": "off"
      }
    }
  ]
}
