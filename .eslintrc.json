{
  "extends": "airbnb-base",
  "rules": {
    "import/prefer-default-export": "allow",
    "no-param-reassign": "off",
    "require-await": "error",
    "no-bitwise": [
      "error",
      {
        "int32Hint": true
      }
    ],
    "no-underscore-dangle": [
      "error",
      {
        "allow": ["_id", "__"]
      }
    ],
    "object-curly-newline": [
      "error",
      {
        "minProperties": 10,
        "consistent": true
      }
    ]
  },
  "overrides": [
    {
        "files": ["*.test.js"],
        "rules": {
            "no-unused-expressions": "off"
        }
    }
  ]
}
