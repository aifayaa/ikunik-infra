{
  "_id": true,
  "category.name": true,
  "categoryId": true,
  "createdAt": true,
  "feedPicture": true,
  "pictures": {
    "$let": {
      "vars": {
        "firstPicture": {
          "$arrayElemAt": [
            "$pictures",
            0
          ]
        }
      },
      "in": {
        "$cond": [
          "$$firstPicture",
          [{
            "mediumHeight": "$$firstPicture.mediumHeight",
            "mediumUrl": "$$firstPicture.mediumUrl",
            "mediumWidth": "$$firstPicture.mediumWidth",
            "thumbHeight": "$$firstPicture.thumbHeight",
            "thumbUrl": "$$firstPicture.thumbUrl",
            "thumbWidth": "$$firstPicture.thumbWidth"
          }],
          []
        ]
      }
    }
  },
  "publicationDate": true,
  "publishedBy": true,
  "summary": true,
  "title": true,
  "user": true,
  "videos": {
    "$let": {
      "vars": {
        "firstVideo": {
          "$arrayElemAt": [
            "$videos",
            0
          ]
        }
      },
      "in": {
        "$cond": [
          "$$firstVideo",
          [{"thumbUrl": "$$firstVideo.thumbUrl"}],
          []
        ]
      }
    }
  }
}
