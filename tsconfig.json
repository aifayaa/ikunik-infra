{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@apps/*": ["apps/*"],
      "@libs/*": ["libs/*"],
      "@organizations/*": ["organizations/*"],
      "@users/*": ["users/*"],
      "@userMetrics/*": ["userMetrics/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["**/node_modules", "**/old_modules", "**/tmp"]
}
