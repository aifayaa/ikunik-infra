{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "users/lib/usersUtils.js"],
  "exclude": ["**/node_modules", "**/old_modules", "**/tmp"]
}
